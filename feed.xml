---
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | default: "Blog" }}</title>
    <description>{{ site.description | default: "Latest posts" }}</description>
    <link>{{ site.url | default: site.github.url }}{{ site.baseurl }}/</link>
    <atom:link href="{{ site.url | default: site.github.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/rss+xml"/>
    {% for post in site.posts limit:20 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <description>{{ post.excerpt | xml_escape }}</description>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
    </item>
    {% endfor %}
  </channel>
</rss>
